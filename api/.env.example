# ─────────────────────────────────────────────
# YouTube AI Platform - API Environment
# ─────────────────────────────────────────────
# Copy this to .env and fill in your values.
# For local dev: copy this to api/.env
# ─────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# Database (local dev: host=localhost, Docker: host=postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/youtube_ai_platform"

# JWT Authentication
JWT_SECRET="change_this_to_a_random_secret_min_32_chars"
JWT_REFRESH_SECRET="change_this_to_another_random_secret_min_32_chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Redis
REDIS_URL="redis://localhost:6379"

# ─── AI Models ───
OLLAMA_HOST="http://localhost:11434"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-pro"

# ─── YouTube API ───
YOUTUBE_API_KEY=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REFRESH_TOKEN=""
YOUTUBE_REDIRECT_URI="http://localhost:4000/api/auth/youtube/callback"
OAUTH_STATE_SECRET="change_this_to_a_random_secret_min_32_chars"

# ─── Token Encryption (REQUIRED for OAuth) ───
# WARNING: If this key changes after tokens are stored, ALL tokens become undecryptable.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=""

# ─── API Security ───
API_KEY=""

# ─── Transcript API ───
TRANSCRIPT_API_KEY=""

# ─── Database Pool ───
DB_POOL_MIN=2
DB_POOL_MAX=10
REDIS_MAX_RETRIES=10

# ─── SMTP ───
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@youtube-ai-platform.com"

# ─── Horror Content Auto-Generation ───
HORROR_AUTO_GENERATE_ENABLED=false
HORROR_GENERATE_CRON="0 6,18 * * *"
HORROR_PLAN_CRON="0 5 * * *"

# ─── Low Memory Mode ───
# Set to "true" to limit Ollama context, batch size, and concurrent renders for <8GB RAM systems
LOW_MEMORY_MODE="false"

# ─── Stock Footage (Free Tiers) ───
# Get a free Pexels API key: https://www.pexels.com/api/
PEXELS_API_KEY=""
# Get a free Pixabay API key: https://pixabay.com/api/docs/
PIXABAY_API_KEY=""

# ─── FFmpeg ───
FFMPEG_PATH="ffmpeg"
FONT_PATH="C:\\Windows\\Fonts\\arial.ttf"
