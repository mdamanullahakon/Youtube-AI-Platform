  jobsFailed    Int      @default(0)
  lastHeartbeat DateTime @default(now())
  startedAt     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([queue])
  @@index([status])
  @@index([lastHeartbeat])
}

model ChannelUsageStats {
