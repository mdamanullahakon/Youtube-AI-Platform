{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=junit --coverage.enabled=true --coverage.reporter=text --coverage.reporter=json",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration",
    "test:api": "vitest run src/__tests__/api",
    "demo:audit": "vitest run src/__tests__/scripts/audit-pipeline-demo.test.ts --reporter=verbose",
    "dev": "node scripts/start-backend.js",
    "dev:nodemon": "nodemon -r dotenv/config src/server.ts",
    "dev:direct": "ts-node -r dotenv/config src/server.ts",
    "build": "tsc",
    "start": "node -r dotenv/config dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:studio": "prisma studio",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset --force",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:db:push": "prisma db push",
    "prebuild": "prisma generate",
    "prisma:diff": "prisma migrate diff --from-migrations prisma/migrations --to-schema-datamodel prisma/schema.prisma",
    "prisma:drift": "prisma migrate diff --from-migrations prisma/migrations --to-schema-datamodel prisma/schema.prisma && echo No drift detected || echo Drift detected",
    "prisma:check": "prisma migrate status",
    "db:up": "docker compose -f ../docker/docker-compose.local.yml up -d postgres redis",
    "db:down": "docker compose -f ../docker/docker-compose.local.yml down",
    "db:reset": "docker compose -f ../docker/docker-compose.local.yml down -v && docker compose -f ../docker/docker-compose.local.yml up -d postgres redis",
    "db:migrate": "prisma migrate dev",
    "db:migrate:safe": "prisma migrate status && prisma migrate diff --from-migrations prisma/migrations --to-schema-datamodel prisma/schema.prisma | findstr /V . && prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node src/seed.ts",
    "orchestrate": "node ../scripts/dev-orchestrator.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.7",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "connect-timeout": "^1.9.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "googleapis": "^144.0.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "morgan": "^1.10.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.0",
    "ollama": "^0.6.3",
    "pino": "^10.3.1",
    "prisma": "^6.19.3",
    "prom-client": "^15.1.3",
    "redis": "^5.12.1",
    "uuid": "^11.0.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "ioredis-mock": "^8.13.1",
    "nodemon": "^3.1.14",
    "redis-server": "^1.2.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "vitest-mock-extended": "^4.0.0"
  }
}
