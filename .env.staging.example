# ═══════════════════════════════════════════════
# YouTube AI Platform — Staging Environment
# ═══════════════════════════════════════════════
# Copy to .env.staging for staging deployment
# ═══════════════════════════════════════════════

DOMAIN=staging.yourdomain.com
FRONTEND_URL=https://${DOMAIN}
NEXT_PUBLIC_API_URL=https://${DOMAIN}

JWT_SECRET=staging_jwt_secret_replace_me
JWT_REFRESH_SECRET=staging_refresh_secret_replace_me
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

POSTGRES_USER=postgres
POSTGRES_PASSWORD=staging_db_password
POSTGRES_DB=youtube_ai_platform_staging

DB_POOL_MIN=1
DB_POOL_MAX=5

REDIS_URL=redis://redis:6379
REDIS_MAX_RETRIES=10

LOG_LEVEL=debug

OLLAMA_MODEL=llama3

GEMINI_API_KEY=

YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_REDIRECT_URI=https://${DOMAIN}/api/auth/youtube/callback

API_KEY=

TRANSCRIPT_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@youtube-ai-platform.com

QUEUE_CONCURRENCY_VIDEO=1
QUEUE_CONCURRENCY_WORKER=2
