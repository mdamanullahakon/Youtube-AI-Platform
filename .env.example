# ─────────────────────────────────────────────
# YouTube AI Platform - Environment Variables
# ─────────────────────────────────────────────
# Copy this to .env and fill in your values.
# For local dev: cp .env.example .env
# ─────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# Database (local: host=localhost, Docker: host=postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/youtube_ai_platform"

# JWT Authentication
JWT_SECRET="change_this_to_a_random_secret_min_32_chars"
JWT_REFRESH_SECRET="change_this_to_another_random_secret_min_32_chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_MAX_RETRIES=10
ENABLE_LOCAL_LEGACY_WORKERS=false

# Database Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── AI Models (Optional - falls back to Ollama if not set) ───
OLLAMA_HOST="http://localhost:11434"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4"

CLAUDE_API_KEY=""
CLAUDE_MODEL="claude-3-opus-20240229"

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-pro"

# ─── Voice AI ───
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# ─── YouTube API ───
# ⚠ NOTE: YouTube OAuth Client ID and Secret are configured in api/.env (single source of truth).
# This project uses a monorepo — the API has its own .env at api/.env
YOUTUBE_API_KEY=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REFRESH_TOKEN=""

# ─── YouTube OAuth ───
YOUTUBE_REDIRECT_URI="http://localhost:4000/api/auth/youtube/callback"
OAUTH_STATE_SECRET="change_this_to_a_random_secret_min_32_chars"

# ─── Transcript API ───
TRANSCRIPT_API_KEY=""

# ─── Encryption ───
# WARNING: In production, generate a 64-char hex key via: openssl rand -hex 32
# If this key changes after tokens are stored, ALL tokens become undecryptable.
ENCRYPTION_KEY=""

# ─── API Security ───
API_KEY=""

# ─── SMTP (Password Reset) ───
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@youtube-ai-platform.com"

# ─── FFmpeg ───
FFMPEG_PATH="ffmpeg"
FONT_PATH="C:\\Windows\\Fonts\\arial.ttf"
