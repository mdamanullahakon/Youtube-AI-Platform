# ═══════════════════════════════════════════════
# YouTube AI Platform — Production Environment
# ═══════════════════════════════════════════════
# Copy this file to .env.production and fill in all values.
#   cp .env.production.example .env.production
# ═══════════════════════════════════════════════

# ─── Domain ────────────────────────────────────
DOMAIN=yourdomain.com
FRONTEND_URL=https://${DOMAIN}
NEXT_PUBLIC_API_URL=https://${DOMAIN}

# ─── JWT (REQUIRED - generate via: openssl rand -hex 64) ──
JWT_SECRET=replace_with_64_char_hex
JWT_REFRESH_SECRET=replace_with_another_64_char_hex
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Database ─────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=youtube_ai_platform
# Used internally by Docker Compose (host=postgres)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Redis ────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_MAX_RETRIES=10

# ─── Logging ──────────────────────────────────
LOG_LEVEL=info

# ─── AI Models (Ollama is default, Gemini is fallback) ──
OLLAMA_MODEL=llama3

# Leave blank to use Ollama as default. Gemini key enables fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# ─── YouTube API (for upload + analytics) ─────
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_REDIRECT_URI=https://${DOMAIN}/api/auth/youtube/callback

# ─── API Security Key (for external API access) ─
API_KEY=

# ─── Transcript API ──────────────────────────
TRANSCRIPT_API_KEY=

# ─── Email (SMTP for password reset) ──────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@youtube-ai-platform.com

# ─── Auto-Content Generation ─────────────────
# Set to "true" to enable automatic daily content generation
# AUTO_GENERATE_ENABLED=false
# Cron schedule for auto-generation (default: every day at 8 AM)
# AUTO_GENERATE_CRON=0 8 * * *

# ─── Horror Content Auto-Generation ──────────
HORROR_AUTO_GENERATE_ENABLED=false
HORROR_GENERATE_CRON="0 6,18 * * *"
HORROR_PLAN_CRON="0 5 * * *"

# ─── Queue Concurrency ────────────────────────
QUEUE_CONCURRENCY_VIDEO=1
QUEUE_CONCURRENCY_WORKER=2
